# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://areabot:areabot_pass@localhost:5432/areabot_db

# ── Auth ──────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI APIs ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email (SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@areabot.ai
SMTP_FROM_NAME=AreaBot

# ── Stripe Billing ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_PRO=price_your-pro-price-id
STRIPE_PRICE_BUSINESS=price_your-business-price-id

# ── Sentry Error Tracking ─────────────────────────────
SENTRY_DSN=

# ── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_WEBHOOK=120/minute
RATE_LIMIT_AUTH=10/minute

# ── App ───────────────────────────────────────────────
APP_NAME=AreaBot
FRONTEND_URL=http://localhost:3002
BACKEND_URL=http://localhost:8000
